      "height": "{height}",
      "batch_size": 1
    }
  },
  "9": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{seed}",
      "steps": "{steps}",
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["3", 0],
      "positive": ["23", 0],
      "negative": ["23", 1],
      "latent_image": ["16", 0]
    }
  },
  "10": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["9", 0],
      "vae": ["5", 0]
    }
  },
  "11": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["10", 0],
      "filename_prefix": "deskad_controlnet"
    }
  }
}
