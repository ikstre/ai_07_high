DESKAD_API_BASE=http://127.0.0.1:8010
DESKAD_PUBLIC_API_BASE=http://127.0.0.1:8010

# Comma-separated CORS allowlist for the FastAPI backend.
# Leave EMPTY (default) to disable CORS responses entirely - the safest default
# because Streamlit calls the backend from the same VM via 127.0.0.1 anyway.
# Add origins only if a remote browser-based client needs cross-origin access.
# Wildcard "*" is intentionally NOT supported by this app.
DESKAD_CORS_ORIGINS=

# Streamlit studio login (single operations account). Plain-text passwords are
# NOT stored - put the SHA256 hex of the password instead. Generate it with:
#   python3 -c "import hashlib;print(hashlib.sha256(b'your-password').hexdigest())"
# Leave both empty to keep the login endpoint in "not_configured" state.
DESKAD_LOGIN_ID=
DESKAD_LOGIN_PASSWORD_SHA256=
# Signup invite code. Anyone with this code can self-register from the login
# page; new users are stored in data/runtime/users.json (salted PBKDF2 hashes).
# Leave empty to disable signup entirely.
DESKAD_SIGNUP_CODE=
# Copy to .env and fill only on the deployment machine. Never commit real keys.
# .env is intentionally ignored by git. Keep API keys and local endpoint tokens there only.
AI_PROVIDER=auto

# OpenAI-compatible text API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4o-mini

# Optional image model. Leave empty to use the built-in SVG poster generator.
OPENAI_IMAGE_MODEL=

# Optional local OpenAI-compatible LLM endpoint, for example http://127.0.0.1:11434/v1
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL=

# Optional HyperCLOVA X adapter.
# Option A: Hugging Face local SEED model via tools/hyperclova_seed_openai_server.py.
#   First accept the model terms on Hugging Face, then set HF_TOKEN in .env if access is gated.
#   Example:
#     HF_TOKEN=
#     HYPERCLOVA_BASE_URL=http://127.0.0.1:11501/v1
#     HYPERCLOVA_MODEL=naver-hyperclovax/HyperCLOVAX-SEED-Text-Instruct-1.5B
#   Smaller fallback:
#     HYPERCLOVA_MODEL=naver-hyperclovax/HyperCLOVAX-SEED-Text-Instruct-0.5B
#   Larger quality option if VRAM allows:
#     HYPERCLOVA_MODEL=naver-hyperclovax/HyperCLOVAX-SEED-Think-14B
#     HYPERCLOVA_SEED_LOAD_IN_4BIT=true
#     HYPERCLOVA_SEED_DEVICE_MAP=auto
#     # Requires optional packages: accelerate bitsandbytes
# Option B: faster HyperCLOVA 8B GGUF via Ollama.
#   Pull once:
#     ollama pull hf.co/naver-ellm/HyperCLOVAX-SEED-Omni-8B-GGUF:Q4_K_M
#   주의: 원본 Omni GGUF는 vision projector(hcxomni)를 포함하는데 현재 Ollama가
#   이 projector 타입을 못 읽어 runner가 죽는다. 광고문구는 텍스트만 필요하므로
#   GGUF 본체만 참조하는 텍스트 전용 모델을 별도 등록해 쓴다:
#     ollama create hyperclova-omni-8b-text:Q4_K_M -f <text-only Modelfile>
#   Then set:
#     HYPERCLOVA_BASE_URL=http://127.0.0.1:11434/v1
#     HYPERCLOVA_MODEL=hyperclova-omni-8b-text:Q4_K_M
# Default mode: OpenAI-compatible gateway. For CLOVA Studio, set:
#   HYPERCLOVA_BASE_URL=https://clovastudio.stream.ntruss.com/v1/openai
#   HYPERCLOVA_MODEL=HCX-005
# Direct mode: set HYPERCLOVA_USE_DIRECT_API=true to call CLOVA Studio chat-completions directly.
#   Direct base URL example: https://clovastudio.stream.ntruss.com
#   App-prefixed URLs are also supported, e.g. https://clovastudio.stream.ntruss.com/testapp
#   Direct mode uses Authorization: Bearer $HYPERCLOVA_API_KEY.
# For local HyperCLOVA X SEED hosting, serve the HF model through an OpenAI-compatible
# vLLM/SGLang/Ollama endpoint and set HYPERCLOVA_BASE_URL to that endpoint's /v1 URL.
HYPERCLOVA_BASE_URL=
HYPERCLOVA_API_KEY=
HYPERCLOVA_MODEL=
HYPERCLOVA_USE_DIRECT_API=false
HYPERCLOVA_APIGW_KEY=

# Optional HyperCLOVA vision input endpoint.
# This is intentionally separate from HYPERCLOVA_BASE_URL. The Ollama text-only
# alias above must not receive OpenAI image_url parts. Point this at an Omni/VLM
# endpoint only when it can actually accept text+image input.
#
# Single-L4 experimental path:
#   1) Check the machine first:
#        conda run -n sprint_high python tools/hyperclova_omni_runtime_probe.py
#   2) Start either vLLM/SGLang, or the Transformers fallback server:
#        HYPERCLOVA_OMNI_LOAD_IN_4BIT=true \
#        HYPERCLOVA_OMNI_DEVICE_MAP=auto \
#        conda run -n sprint_high python tools/hyperclova_omni_openai_vision_server.py
#   3) Then point DeskAd at that OpenAI-compatible vision endpoint:
#        HYPERCLOVA_VISION_BASE_URL=http://127.0.0.1:11601/v1
#        HYPERCLOVA_VISION_MODEL=naver-hyperclovax/HyperCLOVAX-SEED-Omni-8B
#        HYPERCLOVA_SUPPORTS_VISION=true
HYPERCLOVA_VISION_BASE_URL=
HYPERCLOVA_VISION_API_KEY=
HYPERCLOVA_VISION_MODEL=

# Optional HyperCLOVA image output.
# This is also intentionally separate from HYPERCLOVA_BASE_URL. The current
# Ollama text-only GGUF path above cannot generate images. To make the
# HyperCLOVA engine produce images without ComfyUI, run a local image-capable
# HyperCLOVA endpoint and expose it in one of these OpenAI-style modes:
#
#   Option A: HyperCLOVA OmniServe Track B (chat-completions + t2i tool)
#     HYPERCLOVA_IMAGE_MODE=omniserve_chat
#     HYPERCLOVA_IMAGE_BASE_URL=http://127.0.0.1:8000/b/v1
#     HYPERCLOVA_IMAGE_MODEL=track_b_model
#
#   Option B: an OpenAI Images-compatible wrapper
#     HYPERCLOVA_IMAGE_MODE=openai_images
#     HYPERCLOVA_IMAGE_BASE_URL=http://127.0.0.1:8000/v1
#     HYPERCLOVA_IMAGE_MODEL=track_b_model
#
HYPERCLOVA_IMAGE_BASE_URL=
HYPERCLOVA_IMAGE_API_KEY=
HYPERCLOVA_IMAGE_MODEL=
HYPERCLOVA_IMAGE_MODE=omniserve_chat
HYPERCLOVA_IMAGE_TIMEOUT_SECONDS=420
HYPERCLOVA_IMAGE_MAX_ATTEMPTS=1
HYPERCLOVA_IMAGE_MAX_TOKENS=7000
HYPERCLOVA_IMAGE_TEMPERATURE=0.7
# tools/hyperclova_omni_image_server.py(:11602) 측 샘플링/재시도 튜닝.
# base seed는 요청마다 랜덤(요청 body의 seed로 고정 가능). token block 실패 시
# seed를 바꿔 MAX_ATTEMPTS회 재시도. TIME_BUDGET(초) 이후에는 새 attempt를 시작하지
# 않음 — 성공 attempt ~180s + 디코드 ~100s가 더해지므로
# HYPERCLOVA_IMAGE_TIMEOUT_SECONDS >= TIME_BUDGET + 280 을 유지할 것.
# 실패 attempt(tool call 미발생)는 TOOLCALL_CHECK_TOKENS token 안에 조기 중단(0=off).
#HYPERCLOVA_OMNI_IMAGE_MAX_ATTEMPTS=12
#HYPERCLOVA_OMNI_IMAGE_TIME_BUDGET_SECONDS=140
#HYPERCLOVA_OMNI_IMAGE_TOOLCALL_CHECK_TOKENS=48
#HYPERCLOVA_OMNI_IMAGE_TEMPERATURE=0.7
#HYPERCLOVA_OMNI_IMAGE_TOP_P=0.9

# 멀티모달(OpenAI식 text+image 동시 입력) 토글.
# 광고문구 요청에 reference_image_b64(base64 또는 data URL)를 넣으면, 아래 플래그가
# true인 provider에만 OpenAI image_url part로 함께 전송된다. false면 텍스트로 강등.
# 현재 로컬 HyperCLOVA 경로(Ollama 텍스트 전용/Transformers 텍스트 서버)는 vision 미지원이라
# 기본 false 유지. HCX Omni/VLM 서버를 HYPERCLOVA_VISION_* 또는 HYPERCLOVA_IMAGE_*에
# 별도로 연결한 뒤에만 true로.
OPENAI_SUPPORTS_VISION=true
HYPERCLOVA_SUPPORTS_VISION=false
HF_TOKEN=

# Optional Korean LLM experiment slots. Serve each model through vLLM, SGLang, Ollama, LM Studio, or another OpenAI-compatible gateway.
KANANA_BASE_URL=
KANANA_API_KEY=
KANANA_MODEL=
MIDM_BASE_URL=
MIDM_API_KEY=
MIDM_MODEL=

# Optional image generation backend. Values: auto, openai, hyperclova, local_endpoint, comfyui, fallback.
IMAGE_MODEL_BACKEND=auto

# Optional local image worker endpoint that accepts {"prompt": "...", "metadata": {...}}
# The endpoint may return image_base64, image_b64, image, data[0].b64_json, data[0].url, or url.
LOCAL_IMAGE_ENDPOINT=

# Optional ComfyUI worker. COMFYUI_WORKFLOW_PATH should point to an API-format workflow JSON.
# Placeholders in workflow JSON strings: {prompt} {negative_prompt} {width} {height} {seed} {steps}
#   {flux_model_variant} {image_quantization} {lora_name} {lora_strength}
#   {controlnet_image} {controlnet_strength} {denoise}  (also accepts {{double}} braces)
COMFYUI_BASE_URL=
COMFYUI_WORKFLOW_PATH=

# Workflow selector: a directory of API-format workflow JSONs. When set, the
# backend picks <name>.json by request field image_workflow, else flux_<template>
# / flux_<theme>, else COMFYUI_DEFAULT_WORKFLOW. Falls back to COMFYUI_WORKFLOW_PATH
# above when unset. See tools/comfyui_workflows/README.md.
COMFYUI_WORKFLOWS_DIR=tools/comfyui_workflows
COMFYUI_DEFAULT_WORKFLOW=flux_schnell_basic

# {negative_prompt} substitution (default tuned for clean keyboard renders).
# COMFYUI_NEGATIVE_PROMPT=logo, watermark, distorted keyboard, extra keys, unreadable text, low quality

# Local image quality knobs. Composition references default higher because the
# setup map is a coarse layout raster that needs more steps to become realistic.
COMFYUI_STEPS=4
COMFYUI_COMPOSITION_STEPS=8
COMFYUI_IMG2IMG_DENOISE=0.65
COMFYUI_COMPOSITION_DENOISE=0.90

# Optional LoRA / ControlNet for advanced workflows (empty / 0 = no-op placeholders).
COMFYUI_LORA_NAME=
COMFYUI_LORA_STRENGTH=0.0
COMFYUI_CONTROLNET_IMAGE=
COMFYUI_CONTROLNET_STRENGTH=0.0
# depth-ControlNet 배열 고정(flux_controlnet_depth 워크플로). MODEL 파일명을 채우고
# STRENGTH>0 이면, 셋업 구도 레퍼런스 요청이 img2img 대신 ControlNet(depth) 경로로 가
# 셋업 GLB를 헤드리스 렌더한 depth로 65% 배열을 denoise와 독립적으로 고정한다(사진 품질
# 유지). 둘 중 하나라도 비면 기존 img2img로 자연 폴백. 모델은 ComfyUI models/controlnet/ 기준.
# 예: COMFYUI_CONTROLNET_MODEL=FLUX.1-dev-ControlNet-Union-Pro-2.0.safetensors / STRENGTH=0.7
COMFYUI_CONTROLNET_MODEL=

# Image model runtime hints for the worker process. Leave empty unless the worker consumes them.
FLUX_MODEL_VARIANT=
IMAGE_QUANTIZATION=
ENABLE_VAE_TILING=false
ENABLE_XFORMERS=false

AI_REQUEST_TIMEOUT_SECONDS=45
# Slow local quality models can override the generic timeout so copy experiments
# can wait for every selected provider instead of dropping late results.
LLM_REQUEST_TIMEOUT_SECONDS=45
HYPERCLOVA_REQUEST_TIMEOUT_SECONDS=900
LOCAL_LLM_REQUEST_TIMEOUT_SECONDS=180
KANANA_REQUEST_TIMEOUT_SECONDS=120
MIDM_REQUEST_TIMEOUT_SECONDS=120
MAX_UPLOAD_MB=60

# LLM 호출 재시도 정책 (전이성 오류: 연결 실패/타임아웃/5xx/429). 4xx는 즉시 fallback.
# 지수 백오프 + full jitter. 0으로 두면 재시도 비활성화.
LLM_MAX_TOKENS=1024
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SECONDS=0.5
LLM_RETRY_MAX_BACKOFF_SECONDS=8
HYPERCLOVA_SEED_MAX_NEW_TOKENS=1024

# ── GPU worker runtime mode ────────────────────────────────────────────────────
# Controls how text/image GPU workers are started and stopped.
#
#   always_on  (default) — workers are managed externally (systemd/manual).
#              The backend never starts or stops them; it just calls them.
#              Result cache is still active to avoid redundant LLM/ComfyUI calls.
#
#   on_demand  — backend starts the needed worker on cache miss and stops it
#              after GPU_WORKER_IDLE_TIMEOUT_SECONDS of inactivity.
#              Suitable when only one worker type is used at a time.
#
#   exclusive  — like on_demand, but before starting one worker the backend
#              stops the other first. Use on a single-GPU host where FLUX +
#              HyperCLOVA SEED cannot share VRAM simultaneously.
GPU_WORKER_MODE=always_on

# Seconds of inactivity after which on_demand/exclusive workers are stopped.
GPU_WORKER_IDLE_TIMEOUT_SECONDS=600

# Stop ComfyUI immediately after the last image job reaches a terminal state.
# Completed ComfyUI output is copied into the job store before stopping so poster
# generation and the lightweight quality gate can still read the image.
IMAGE_WORKER_STOP_AFTER_JOB=true

# File path for the inter-process worker lock. Must be on a local filesystem.
GPU_WORKER_LOCK_PATH=data/runtime/gpu_worker.lock

# Directory for disk result cache. Defaults to data/runtime/cache/.
# Add this path to .gitignore if you change it.
# GPU_WORKER_CACHE_DIR=data/runtime/cache

# Result cache eviction (bounds long-term disk growth). Each write prunes its
# directory: expired entries first (TTL), then least-recently-used beyond the
# entry cap. Reads bump recency. Set <=0 to disable that dimension.
GPU_WORKER_CACHE_MAX_ENTRIES=500
GPU_WORKER_CACHE_MAX_AGE_DAYS=30

# Text worker (HyperCLOVA X SEED local OpenAI-compatible server).
# Used only when GPU_WORKER_MODE=on_demand or exclusive.
TEXT_WORKER_CMD=conda run -n sprint_high python tools/hyperclova_seed_openai_server.py
TEXT_WORKER_HEALTH_URL=http://127.0.0.1:11501/health
TEXT_WORKER_STARTUP_TIMEOUT_SECONDS=60
HYPERCLOVA_SEED_LOAD_IN_4BIT=false
HYPERCLOVA_SEED_LOAD_IN_8BIT=false
HYPERCLOVA_SEED_DEVICE_MAP=
HYPERCLOVA_SEED_TORCH_DTYPE=auto
HYPERCLOVA_SEED_TRUST_REMOTE_CODE=false

# Image worker systemd service name and health endpoint.
# Used only when GPU_WORKER_MODE=on_demand or exclusive.
IMAGE_WORKER_SERVICE=comfyui
IMAGE_WORKER_HEALTH_URL=http://127.0.0.1:8188/system_stats

# Shared host folders for reusable model/data assets.
# Large downloaded files should live here instead of the git workspace.
DESKAD_SHARED_DATA_DIR=/opt/shared_data
DESKAD_SHARED_MODEL_DIR=/opt/shared_model

# Optional STEP converter command. Use quoted placeholders {input} and {output} exactly.
#
# Option A – trimesh (lightweight, install: pip install trimesh[all]):
#   STEP_CONVERTER_CMD=python -c "import trimesh,sys; s=trimesh.load(sys.argv[1]); s.export(sys.argv[2])" {input} {output}
#
# Option B – Blender 3.x headless (install Blender separately):
#   STEP_CONVERTER_CMD=blender --background --python /opt/deskad/step_to_glb.py -- {input} {output}
#
# Option C – FreeCADCmd (install: sudo apt install freecad on Ubuntu):
#   STEP_CONVERTER_CMD=FreeCADCmd -c "import FreeCAD,Import,Mesh; Import.open('{input}'); Mesh.export([o for o in FreeCAD.ActiveDocument.Objects], '{output}')"
#
# Current env: none of the above are installed in sprint_high. Proxy GLB is used as fallback.
STEP_CONVERTER_CMD=
STEP_CONVERTER_TIMEOUT_SECONDS=120
# GitHub automation token for PR creation. Copy to .env only; never commit real token values.
# Required scopes: repo for classic PAT, or pull_requests:write + contents:read for fine-grained PAT.
GITHUB_TOKEN=
