# 빌드 컨텍스트 = deskad_keyboard_demo/
# 비밀·런타임 생성물·GPU 전용 자산을 이미지에서 제외한다.

# 비밀: 절대 이미지에 굽지 않는다. 런타임에 env_file/secret으로 주입.
.env
.env.*
!.env.example

# 런타임 생성물(볼륨으로 마운트하거나 컨테이너에서 새로 생성)
static/
data/runtime/
*.log
fastapi.err.log
streamlit.err.log

# 로컬 전용 문서(작업로그/핸드오프/리포트). docs/deploy.md 같은 공개 가이드도
# 이미지에는 불필요하므로 통째로 제외.
docs/

# 파이썬/도구 캐시
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/

# 런타임에 불필요한 무거운/개발 전용 자산
tests/
training/
tools/omni_vision_decoder/

# VCS·에디터 잡동사니
.git/
.gitignore
.vscode/
.idea/
.DS_Store
